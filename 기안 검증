async function runValidation(){
  const btn=$('btnValidate');
  btn.disabled=true; btn.innerHTML='<div class="spin"></div> 검증 중...';
  globalErrors=0; $('r_core').innerHTML='';

  try{
    // 증빙 AI 호출
    let mailData=null, contractData=null, scmData=null, bizData=null;
    // 증빙 AI 병렬 호출 (순차 → 동시 실행으로 3~4배 빨라짐)
    const aiTasks=[];
    if(evidenceFiles.mail.length) aiTasks.push(callAI(evidenceFiles.mail[0],P_MAIL,1.0).then(d=>mailData=d).catch(()=>null));
    if(evidenceFiles.contract.length) aiTasks.push(callAI(evidenceFiles.contract[0],P_CONTRACT,1.0).then(d=>contractData=d).catch(()=>null));
    if(evidenceFiles.scm.length) aiTasks.push(callAI(evidenceFiles.scm[0],P_SCM,1.0).then(d=>scmData=d).catch(()=>null));
    if(evidenceFiles.bizreg.length) aiTasks.push(callAI(evidenceFiles.bizreg[0],P_BIZ,1.0).then(d=>bizData=d).catch(()=>null));
    await Promise.all(aiTasks);

    // 엑셀 합산
    let xl = null;
    if(detectedType==='매입정산' && excelFiles.length>0){
      // 매입: 여러 기안 파일 (사업소득+기타소득) 합산
      xl={소득별:{},총합계:{공급가액:0,소득세:0,주민세:0,실지급액:0},지급요청일:null,귀속년월:null,파일목록:[]};
      excelFiles.forEach(f=>{
        const d=f.data;
        xl.파일목록.push({이름:f.name, 소득유형:d.소득유형, 공급:d.공급가액});
        // 소득유형별 분류 (충돌 시 합산)
        const key = d.소득유형 || '기타';
        if(!xl.소득별[key]) xl.소득별[key]={공급가액:0,소득세:0,주민세:0,실지급액:0,파일들:[]};
        xl.소득별[key].공급가액 += d.공급가액||0;
        xl.소득별[key].소득세 += d.소득세||0;
        xl.소득별[key].주민세 += d.주민세||0;
        xl.소득별[key].실지급액 += d.실지급액||0;
        xl.소득별[key].파일들.push(f.name);
        // 총합계 누적
        xl.총합계.공급가액 += d.공급가액||0;
        xl.총합계.소득세 += d.소득세||0;
        xl.총합계.주민세 += d.주민세||0;
        xl.총합계.실지급액 += d.실지급액||0;
        if(!xl.지급요청일) xl.지급요청일=d.지급요청일;
        if(!xl.귀속년월) xl.귀속년월=d.귀속년월;
      });
    } else if(excelFiles.length>0){
      xl={테라핀매출액:0,계산서발행액:0,총공급가:0,MG차감액:0,해외Tax:0,실지급액:0,예상매출계산서:0,날짜:null,이메일:null,사업자번호:null,제목:null};
      excelFiles.forEach(f=>{
        xl.테라핀매출액+=(f.data.테라핀매출액||0);
        xl.계산서발행액+=(f.data.계산서발행액||0);
        xl.총공급가+=(f.data.총공급가||0);
        xl.MG차감액+=(f.data.MG차감액||0);
        xl.해외Tax+=(f.data.해외Tax||0);
        xl.실지급액+=(f.data.실지급액||0);
        if(!xl.날짜) xl.날짜=f.data.날짜;
        if(!xl.이메일) xl.이메일=f.data.이메일;
        if(!xl.사업자번호) xl.사업자번호=f.data.사업자번호;
        if(!xl.제목) xl.제목=f.data.제목;
      });
      xl.예상매출계산서=xl.계산서발행액 || (xl.총공급가-xl.MG차감액-xl.해외Tax);
    }

    // 폼 값 읽기
    const fv = k => { const el=$(k); return el?el.value.trim():''; };
    const fn = k => parseAmt(fv(k));

    // 보고서 생성
    const typeLabel = detectedType==='매출정산'?'① 매출 정산':detectedType==='매입정산'?'② 매입 정산':'③ 선인세/매절';
    let h = `<div style="margin-bottom:20px">
      <h2 style="font-size:18px;color:var(--navy);margin:0 0 6px">기안서 검증 보고서</h2>
      <div style="font-size:12px;color:var(--sub)">유형: <b>${typeLabel}</b> &nbsp;|&nbsp; 제목: ${fv('f_title')||'미기재'} &nbsp;|&nbsp; 검증일: ${new Date().toLocaleDateString('ko-KR')}</div>
    </div>`;

    /* ---- 매출 정산 ---- */
    if(detectedType==='매출정산'){
      h += `<div class="gt">📋 텍스트 항목 대사</div>`;
      h += cmpText('1. 작성일자', fv('f_date'), xl?.날짜||mailData?.작성일자||'', '기안서', '엑셀/메일');
      h += cmpText('2. 거래처명', fv('f_client'), mailData?.보낸사람_회사명||'', '기안서', '메일');
      h += cmpText('3. 사업자등록번호', fv('f_bizno'), xl?.사업자번호||mailData?.사업자등록번호||bizData?.사업자등록번호||'', '기안서', '증빙');
      h += cmpText('4. 이메일', fv('f_email'), mailData?.계산서수신이메일||mailData?.보낸사람_이메일||xl?.이메일||'', '기안서', '메일/엑셀');
      h += cmpText('5. 입금 예정일', fv('f_duedate'), mailData?.입금예정일||'', '기안서', '메일');

      // 기안 제목에서 발행마감일 추출 및 세금계산서 발행 안내
      const title = fv('f_title');
      const titleDeadline = title.match(/발행마감일\s*[:：]\s*([\d.\/\-]+)/)?.[1] || '';
      const hasIssueInfo = titleDeadline || draftData?.발행마감일 || draftData?.세금계산서_발행건수 || draftData?.세금계산서_발행조건 || mailData?.발행마감일 || mailData?.발행요청사항;

      if(hasIssueInfo){
        h += `<div class="gt">📌 세금계산서 발행 안내</div>`;
        // 발행 건수 (매우 중요)
        if(draftData?.세금계산서_발행건수){
          h += mkCI('warn','!','⭐ 발행 건수', `<b>총 ${draftData.세금계산서_발행건수}건</b> 발행 필요 (기안서 명시)`, '');
        }
        // 발행 조건 (각각/통합/품목 구분)
        if(draftData?.세금계산서_발행조건){
          h += mkCI('warn','!','⭐ 발행 방식', draftData.세금계산서_발행조건, '');
        }
        // 발행마감일
        if(titleDeadline) h += mkCI('info','i','기안서 발행마감일 (제목)', titleDeadline, '');
        if(draftData?.발행마감일 && draftData.발행마감일!==titleDeadline) h += mkCI('info','i','기안서 발행마감일 (본문)', draftData.발행마감일, '');
        if(mailData?.발행마감일) h += mkCI('info','i','메일 발행마감일', mailData.발행마감일, '');
        // 메일 발행 요청사항
        if(mailData?.발행요청사항) h += mkCI('warn','!','메일 발행 요청사항', mailData.발행요청사항, '');
      }

      h += `<div class="gt">🧮 금액 대사</div>`;

      // 6. 총공급가액: 기안서 값이 매출액(Gross)과 일치하는지, 계산서(Net)과 일치하는지 확인
      const supplyVal = fn('f_supply');
      if(xl && supplyVal!==null){
        const matchGross = Math.abs(supplyVal-(xl.테라핀매출액||0))<=5;
        const matchInvoice = Math.abs(supplyVal-(xl.계산서발행액||0))<=5;
        if(matchInvoice){
          h+=mkCI('pass','✓','6. 총공급가액','계산서 발행 기준 — 일치 ✓',mkDiff([{tag:'기안서',val:fmtAmt(supplyVal)},{tag:'엑셀(계산서)',val:fmtAmt(xl.계산서발행액),cls:'s2'}]));
        } else if(matchGross){
          h+=mkCI('pass','✓','6. 총공급가액','테라핀 매출액(Gross) — 일치 ✓',mkDiff([{tag:'기안서',val:fmtAmt(supplyVal)},{tag:'엑셀(매출액)',val:fmtAmt(xl.테라핀매출액),cls:'s2'}]));
        } else {
          globalErrors++;
          h+=mkCI('fail','✕','6. 총공급가액','매출액/계산서 모두 불일치 ⚠',mkDiff([{tag:'기안서',val:fmtAmt(supplyVal)},{tag:'엑셀(매출액)',val:fmtAmt(xl.테라핀매출액),cls:'s2'},{tag:'엑셀(계산서)',val:fmtAmt(xl.계산서발행액),cls:'s2'}]));
        }
      } else if(xl){
        h+=mkCI('info','i','6. 총공급가액','폼 미입력 — 참고: 엑셀 매출액 '+fmtAmt(xl.테라핀매출액)+', 계산서 '+fmtAmt(xl.계산서발행액),'');
      }

      if(xl?.MG차감액>0||fn('f_mg')>0)
        h += cmpAmt('7. MG 차감액', fn('f_mg'), xl?.MG차감액, '기안서', '엑셀', 5);

      // 8. 세금계산서 발행액
      const draftAmt = fn('f_total')||fn('f_supply');
      if(xl){
        const matchInv = Math.abs(draftAmt-(xl.계산서발행액||0))<=5;
        const matchGross2 = Math.abs(draftAmt-(xl.테라핀매출액||0))<=5;
        if(matchInv){
          h+=mkCI('pass','✓','8. 세금계산서 발행액','계산서 발행액 — 일치 ✓',mkDiff([{tag:'기안서',val:fmtAmt(draftAmt)},{tag:'엑셀(계산서)',val:fmtAmt(xl.계산서발행액),cls:'s2'}]));
        } else if(matchGross2){
          h+=mkCI('pass','✓','8. 세금계산서 발행액','Gross(MG차감 없음) 발행 — 일치 ✓',mkDiff([{tag:'기안서',val:fmtAmt(draftAmt)},{tag:'엑셀(매출액)',val:fmtAmt(xl.테라핀매출액),cls:'s2'}]));
        } else {
          globalErrors++;
          h+=mkCI('fail','✕','8. 세금계산서 발행액','매출액/계산서 모두 불일치 ⚠',mkDiff([{tag:'기안서',val:fmtAmt(draftAmt)},{tag:'엑셀(매출액)',val:fmtAmt(xl.테라핀매출액),cls:'s2'},{tag:'엑셀(계산서)',val:fmtAmt(xl.계산서발행액),cls:'s2'}]));
        }
      }

      if(scmData){
        h += `<div class="gt">💻 SCM 교차 대사</div>`;
        h += cmpAmt('9. SCM 실지급액', draftAmt, parseAmt(scmData.SCM실지급액)||parseAmt(scmData.공급가액), '기안서', 'SCM', 5);
      }
    }

    /* ---- 매입 정산 ---- */
    else if(detectedType==='매입정산'){
      h += `<div class="gt">📋 기본 항목</div>`;
      h += cmpText('1. 작성일자', fv('f_date'), '', '기안서', '—');

      if(xl){
        h += cmpText('2. 지급요청일', fv('f_duedate'), xl.지급요청일||'', '기안서', '엑셀');

        // 지급 건수 대사 (기안서 표 행수 vs 엑셀 파일 수)
        const draftCount = parseAmt(fv('f_count'));
        const xlCount = xl.파일목록?.length || 0;
        if(draftCount && xlCount){
          const okCount = draftCount === xlCount;
          if(!okCount) globalErrors++;
          h += mkCI(okCount?'pass':'fail', okCount?'✓':'✕', '3. 지급 건수',
            okCount ? `일치 ✓ (기안서 ${draftCount}건 = 엑셀 ${xlCount}개)` : `불일치 ⚠ (기안서 ${draftCount}건 ≠ 엑셀 ${xlCount}개)`, '');
        }

        // 첨부 파일 목록 표시
        if(xl.파일목록 && xl.파일목록.length>0){
          h += `<div class="gt">📎 분석된 첨부 파일 (${xl.파일목록.length}개)</div>`;
          for(let f of xl.파일목록){
            h += mkCI('info','i', f.소득유형||'구분불명', f.이름+' → '+fmtAmt(f.공급)+'원', '');
          }
        }

        // 소득유형별 내역
        h += `<div class="gt">🧮 소득유형별 내역</div>`;
        const 유형keys = Object.keys(xl.소득별||{});
        if(유형keys.length>0){
          for(let key of 유형keys){
            const a = xl.소득별[key];
            h += `<div style="font-size:12px;font-weight:700;color:var(--accent);margin:10px 0 5px;padding-left:4px">▸ ${key}</div>`;
            h += mkCI('info','i', key+' 공급가액', fmtAmt(a.공급가액), '');
            h += mkCI('info','i', key+' 소득세', fmtAmt(a.소득세), '');
            h += mkCI('info','i', key+' 주민세', fmtAmt(a.주민세), '');
            h += mkCI('info','i', key+' 실지급액', fmtAmt(a.실지급액), '');
          }
        }

        h += `<div class="gt">📊 총합계 대사 (기안서 ↔ 엑셀 합산)</div>`;
        h += cmpAmt('총 공급가액', fn('f_supply'), xl.총합계?.공급가액, '기안서', '엑셀합계', 10);
        h += cmpAmt('총 소득세', fn('f_incometax'), xl.총합계?.소득세, '기안서', '엑셀합계', 10);
        h += cmpAmt('총 주민세', fn('f_restax'), xl.총합계?.주민세, '기안서', '엑셀합계', 10);
        h += cmpAmt('총 실지급액', fn('f_netpay'), xl.총합계?.실지급액, '기안서', '엑셀합계', 10);
      } else {
        h += mkCI('warn','!','엑셀 미첨부','지급내역 엑셀이 없어 금액 교차 검증 불가','');
      }

      if(bizData){
        h += `<div class="gt">🏢 사업자등록증</div>`;
        h += mkCI('info','i','사업자등록증 확인',`${bizData.상호||'—'} / ${bizData.사업자등록번호||'—'}`,mkDiff([{tag:'등록증',val:`${bizData.상호} (${bizData.사업자등록번호})`,cls:'s2'}]));
      }
    }

    /* ---- 선인세/매절 ---- */
    else {
      h += `<div class="gt">📋 텍스트 항목 대사</div>`;
      h += cmpText('1. 작성일자', fv('f_date'), mailData?.작성일자||contractData?.작성일자||'', '기안서', '메일/계약서');
      h += cmpText('2. 증빙구분', fv('f_proof'), '', '기안서', '—');
      h += cmpText('3. 고객명', fv('f_client'), contractData?.을회사명||mailData?.보낸사람_회사명||'', '기안서', '계약서/메일');
      h += cmpText('4. 사업자등록번호', fv('f_bizno'), contractData?.을사업자번호||bizData?.사업자등록번호||mailData?.사업자등록번호||'', '기안서', '증빙');
      h += cmpText('5. 이메일', fv('f_email'), mailData?.계산서수신이메일||mailData?.보낸사람_이메일||'', '기안서', '메일');
      h += cmpText('6. 입금 예정일', fv('f_duedate'), contractData?.지급조건||mailData?.입금예정일||'', '기안서', '계약서/메일');

      h += `<div class="gt">🧮 금액 대사 (VAT 호환)</div>`;
      h += cmpAmtVAT('7. 공급가액', fn('f_supply'), parseAmt(contractData?.총계약금액)||parseAmt(mailData?.공급가액)||parseAmt(mailData?.총금액), '기안서', '계약서/메일');

      if(fn('f_vat')!==null){
        h += mkCI('info','i','8. 부가가치세',fmtAmt(fn('f_vat')),mkDiff([{tag:'기안서',val:fmtAmt(fn('f_vat'))}]));
      }
      if(fn('f_total')!==null){
        h += cmpAmtVAT('9. 합계(세금계산서 발행액)', fn('f_total'), parseAmt(contractData?.총계약금액)||parseAmt(mailData?.총금액), '기안서', '계약서/메일');
      }

      if(bizData){
        h += `<div class="gt">🏢 사업자등록증 확인</div>`;
        h += cmpText('사업자등록번호', fv('f_bizno'), bizData?.사업자등록번호||'', '기안서', '등록증');
      }
    }

    /* ---- 최종 판정 ---- */
    h += globalErrors===0
      ? `<div style="background:var(--ok-bg);border:2px solid var(--ok);padding:20px;text-align:center;border-radius:10px;margin-top:24px">
           <h2 style="color:var(--ok);margin:0 0 8px">✅ 교차 검증 완료 — 오류 없음</h2>
           <p style="color:#555;font-size:13px;margin:0">기안서와 증빙 자료가 일치합니다.</p></div>`
      : `<div style="background:var(--err-bg);border:2px solid var(--err);padding:20px;text-align:center;border-radius:10px;margin-top:24px">
           <h2 style="color:var(--err);margin:0 0 8px">❌ ${globalErrors}건 불일치 발견</h2>
           <p style="color:#555;font-size:13px;margin:0">붉은색(✕) 항목을 확인 후 기안서를 수정하세요.</p></div>`;

    h += `<div style="text-align:center;margin-top:20px">
      <button class="btn btn-green" onclick="window.print()" style="max-width:300px;margin:0 auto">🖨️ 보고서 PDF 저장</button>
      <button style="margin-top:8px;padding:8px 20px;border:1px solid var(--border);border-radius:6px;background:transparent;cursor:pointer;font-size:12px" onclick="location.reload()">↩ 처음으로</button>
    </div>`;

    $('r_core').innerHTML = h;
    $('reportCard').classList.add('show');
    $('reportCard').scrollIntoView({behavior:'smooth'});

  }catch(e){
    alert('검증 중 오류: '+e.message);
  }finally{
    btn.disabled=false; btn.innerHTML='🧮 최종 검증 실행';
  }
}
</script>
</body>
</html>
