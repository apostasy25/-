.sb{background:rgba(255,255,255,.2);color:#fff;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px}
.cb{padding:16px 18px}

/* API 설정 */
.api-bar{background:var(--white);border:1.5px solid #f0c96a;border-radius:10px;margin-bottom:13px;padding:10px 14px;display:flex;align-items:center;gap:8px}
.api-bar label{font-size:11px;font-weight:700;color:#7a5800;white-space:nowrap}
.api-bar input{flex:1;height:32px;border:1px solid var(--border);border-radius:6px;padding:0 10px;font-size:12px;font-family:monospace}
.api-bar button{height:32px;padding:0 12px;background:var(--navy);color:#fff;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer}

/* 드롭존 */
.drop{border:2px dashed var(--border);border-radius:9px;padding:18px;text-align:center;cursor:pointer;background:#fafbfd;transition:.2s}
.drop.over{border-color:var(--accent);background:var(--accent-l)}
.drop.done{border-color:var(--ok);border-style:solid;background:var(--ok-bg)}
.drop-ic{font-size:22px;margin-bottom:4px}
.drop p{font-size:11px;color:var(--sub)}
.drop .cnt{font-size:10px;color:var(--accent);margin-top:3px;font-weight:600}
.opt-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
@media(max-width:600px){.opt-grid{grid-template-columns:1fr}}

/* 유형 뱃지 */
.type-badge{display:inline-block;padding:5px 14px;border-radius:20px;font-size:13px;font-weight:700;margin:8px 0}
.type-badge.t1{background:#dbeafe;color:#1e40af}
.type-badge.t2{background:#fce7f3;color:#9d174d}
.type-badge.t3{background:#d1fae5;color:#065f46}

/* 버튼 */
.btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;height:50px;border:none;border-radius:12px;font-size:14px;font-weight:700;cursor:pointer;margin:8px 0}
.btn-primary{background:var(--navy);color:#fff}
.btn-secondary{background:#fff;color:var(--navy);border:2px solid var(--navy) !important}
.btn-green{background:#27ae60;color:#fff}
.btn:disabled{opacity:.5;cursor:not-allowed}

/* 폼 */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.fg{display:flex;flex-direction:column;gap:3px}
.fg.full{grid-column:1/-1}
.fg label{font-size:11px;font-weight:700;color:var(--navy)}
.fg input,.fg select{height:34px;border:1px solid var(--border);border-radius:6px;padding:0 10px;font-size:12px}
.fg input.num{text-align:right;font-weight:bold;color:var(--accent)}
.fg input:read-only{background:#f4f6fb;color:var(--sub)}

/* 검증 결과 아이템 */
.ci{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:8px;margin-bottom:7px}
.ci.pass{background:var(--ok-bg);border:1.5px solid #b2e0cc}
.ci.fail{background:var(--err-bg);border:1.5px solid #f5c0bb}
.ci.info{background:#fdfdfd;border:1.5px solid var(--border)}
.ci.warn{background:var(--warn-bg);border:1.5px solid #f0e4bb}
.cs{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;font-weight:700;margin-top:2px;color:#fff}
.ci.pass .cs{background:var(--ok)}
.ci.fail .cs{background:var(--err)}
.ci.info .cs{background:var(--sub)}
.ci.warn .cs{background:var(--warn)}
.cc{flex:1}
.cl-lbl{font-size:11px;font-weight:700;color:var(--navy);margin-bottom:2px}
.cl-det{font-size:12px;font-weight:600;line-height:1.4}
.diff{margin-top:6px;display:flex;flex-direction:column;gap:4px;background:#fff;padding:7px 10px;border-radius:6px;border:1px solid #eee}
.dr{display:flex;align-items:center;gap:6px;font-size:12px}
.dtag{font-size:10px;font-weight:700;padding:2px 6px;border-radius:3px;border:1px solid var(--border);background:#f4f6fb;color:var(--navy)}
.dtag.s2{background:#e3f5ec;color:#1a7f4b;border-color:#b2e0cc}
.gt{font-size:13px;font-weight:700;color:var(--navy);margin:16px 0 10px;padding-left:8px;border-left:3px solid var(--accent)}

/* 스피너 */
.spin{width:18px;height:18px;border:2.5px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:sp .7s linear infinite;display:inline-block}
@keyframes sp{to{transform:rotate(360deg)}}

/* 결과 카드 */
.rc{display:none}.rc.show{display:block}

/* 안내 박스 */
.notice{padding:10px 14px;border-radius:8px;font-size:11px;margin-bottom:12px;line-height:1.5}
.notice.blue{background:var(--accent-l);border:1px solid #c0d4f0;color:#1e3a6e}
.notice.green{background:var(--ok-bg);border:1px solid #b2e0cc;color:var(--ok)}
.notice.yellow{background:var(--warn-bg);border:1px solid #f0e4bb;color:#7a5800}

/* 숨김 */
.hidden{display:none !important}

/* 인쇄 */
@media print{
