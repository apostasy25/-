.hd h1{font-size:17px;font-weight:700;color:var(--navy)}
.hd h1 span{font-size:11px;color:var(--sub);font-weight:400}
.hd p{font-size:11px;color:var(--sub);margin-top:2px}

/* 카드 */
.card{background:var(--white);border:1px solid var(--border);border-radius:13px;margin-bottom:13px;overflow:hidden}
.ch{background:var(--navy);padding:12px 18px;display:flex;align-items:center;gap:9px}
