<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap');
:root{
  --navy:#1a2744;--navy-l:#2a3a60;--accent:#3b6fd4;--accent-l:#e8edf8;
  --ok:#1a7f4b;--ok-bg:#eafaf1;--err:#c0392b;--err-bg:#fdf0ee;
  --warn:#b7700a;--warn-bg:#fef9ec;--border:#d8dde8;
  --text:#1a2744;--sub:#6b7a99;--bg:#f4f6fb;--white:#fff;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--text);padding:24px 16px 80px}
.wrap{max-width:760px;margin:0 auto}

/* 헤더 */
