.bsec{background:#64748b}.bsec:hover{background:#475569}
.bgo{background:#7c3aed;font-size:14px;padding:10px 22px}.bgo:hover{background:#6d28d9}
.bdel{background:#dc2626;padding:4px 8px;font-size:11px}.bdel:hover{background:#b91c1c}
table{border-collapse:collapse;width:100%;font-size:11px}
th,td{border:1px solid #e2e8f0;padding:5px 7px;text-align:left;vertical-align:top}
