</style>
</head>
<body>
<h1>📋 정산서 검증기 v3 (최종 딥러닝 완전체)</h1>
<div class="sub">원본 파일 수정 없음 · 메모리에서 읽기만 · 4개 시트 통합 리포트 지원</div>

<div class="info-box">
  <b>[딥러닝 검증 핵심 로직 탑재]</b><br>
  - 예외사전 및 복합조건: 제호 변경('톱클래스 황녀님'), 묶음/세트 조건('남편이 자는데 시리즈') 초강력 텍스트 압축 매칭<br>
  - 특수 텍스트 정제: HTML 기호(&amp;), NBSP(유령 공백) 완벽 호환 변환 적용<br>
  - 연계 검증: RD 마스터에서 발견된 치명적 오타(사기부터 연애까지 등)는 정산서 검증 리포트에서도 에러로 적발<br>
  - 자동화: 원작료 파일 스킵, RAW/Raw 시트 최우선 적용, 미스터블루 와이드 스캔 지원
</div>

<div class="card">
  <h2 class="hg">① RD 관리 파일</h2>
  <div id="rdDrop" class="file-drop" onclick="$('rdFile').click()">
    <input type="file" id="rdFile" accept=".xlsx,.xlsm,.xlsb,.xls" style="display:none">
    <div style="font-size:13px">🗂️ RD 관리 파일 드래그 또는 클릭</div>
    <div id="rdInfo" style="margin-top:6px;font-weight:600;color:#059669"></div>
  </div>
  <div style="margin-top:10px">
    <div class="row"><label>시트</label><select id="rdSh"><option>(로드 후 선택)</option></select></div>
    <div class="row"><label>제목행</label><input type="number" id="rdHdr" value="5" min="1" style="width:65px"></div>
    <div class="row">
      <label>열 (B~G)</label>
      <span style="font-size:11px;color:#64748b">플랫폼작품명:</span><input type="text" id="rB" value="B" style="width:40px">
      <span style="font-size:11px;color:#64748b">당사작품명:</span><input type="text" id="rC" value="C" style="width:40px">
      <span style="font-size:11px;color:#64748b">연재:</span><input type="text" id="rD" value="D" style="width:40px">
      <span style="font-size:11px;color:#64748b">단행:</span><input type="text" id="rE" value="E" style="width:40px">
      <span style="font-size:11px;color:#64748b">본명:</span><input type="text" id="rF" value="F" style="width:40px">
      <span style="font-size:11px;color:#64748b">필명:</span><input type="text" id="rG" value="G" style="width:40px">
    </div>
  </div>
</div>

<div class="card">
  <h2 class="hb">② 정산서 — 서비스월/정산월 앵커 자동 탐지</h2>
  <div id="psDrop" class="file-drop" onclick="$('psFile').click()">
    <input type="file" id="psFile" accept=".xlsx,.xlsm,.xlsb,.xls" multiple style="display:none">
    <div style="font-size:13px">📑 정산서 파일을 드래그하거나 클릭 (복수 가능)</div>
  </div>
  <div id="psCards"></div>
</div>

<div class="card">
  <h2 class="ho">③ 실행</h2>
  <div class="row">
    <button class="bgo" onclick="runAll()">🔍 전체 검증</button>
    <button class="bsec" onclick="runRd()">Req 1만</button>
    <button class="bsec" onclick="clearLog()">로그 지우기</button>
    <button class="bdel" onclick="resetAll()">초기화</button>
  </div>
  <div id="lg" class="log" style="margin-top:8px;display:none"></div>
</div>

<div class="card" id="resCard" style="display:none">
  <h2 class="hp">④ 결과</h2>
  <div class="sum" id="sum"></div>
  <div class="row" style="margin:4px 0 8px"><button onclick="exportXlsx()">📥 엑셀 저장 (리포트 + 당사검증 10열 데이터)</button></div>
  <div class="tabs">
    <div class="tab on" data-t="rd" onclick="stab('rd')">Req 1 — RD 검증</div>
    <div class="tab" data-t="ps" onclick="stab('ps')">Req 2 — 정산서 검증</div>
  </div>
  <div id="t-rd" class="tc on">
    <div id="rdPatternInfo" style="margin-bottom:8px"></div>
    <div class="fr"><label style="min-width:auto">유형:</label><select id="rflt" onchange="drawRd()"><option value="">전체</option></select><span style="font-size:11px;color:#64748b" id="rcnt"></span></div>
    <div class="res-sec"><table id="rTbl"><thead></thead><tbody></tbody></table></div>
  </div>
  <div id="t-ps" class="tc">
    <div class="fr"><label style="min-width:auto">유형:</label><select id="pflt" onchange="drawPs()"><option value="">전체</option></select>
    <label style="min-width:auto">파일:</label><select id="pffl" onchange="drawPs()"><option value="">전체</option></select><span style="font-size:11px;color:#64748b" id="pcnt"></span></div>
    <div class="res-sec"><table id="pTbl"><thead></thead><tbody></tbody></table></div>
  </div>
</div>

<script>
"use strict";
const $=id=>document.getElementById(id);

// ========== 전역 ==========
let RD=null, PS=[];
let rdMap=null, rdByC=null;
let rIss=[], pIss=[], pSta=[], rdTotal=0;
let learnedTags=[];  
let finalOutput = []; 
let riskyBKeys = new Set(); 

// [수정] 실무 예외 강제 패스 사전 (기호와 공백을 모두 없애서 등록)
const EXCEPTION_DICT = {
    "악당황실의흑막": "톱클래스황녀님",
    "아주특별한연애1": "에로틱한연애",
    "아주특별한연애2": "늑대의연애",
    "아주특별한연애3": "비낭만적일상의연애",
    "컬러시리즈": "운명처럼스며들다"
};

// ========== 유틸 ==========
function log(m,t=""){const e=$("lg");e.style.display="block";const ts=new Date().toLocaleTimeString();const c=t==="e"?"#fca5a5":t==="o"?"#86efac":"#cbd5e1";e.innerHTML+=`<div style="color:${c}">[${ts}] ${m}</div>`;e.scrollTop=e.scrollHeight}
function clearLog(){$("lg").innerHTML=""}

// 텍스트 클렌징
function norm(s){
    if(s==null) return "";
    let str = String(s);
    str = str.replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">");
    return str.replace(/[\u00A0\u200B]/g," ").trim().replace(/\s+/g," ").toLowerCase();
}
function c2i(l){l=String(l||"").trim().toUpperCase();if(!l)return-1;let n=0;for(let i=0;i<l.length;i++){const c=l.charCodeAt(i);if(c<65||c>90)return-1;n=n*26+(c-64)}return n-1}
function i2c(i){let s="";i++;while(i>0){i--;s=String.fromCharCode(65+(i%26))+s;i=Math.floor(i/26)}return s}
function cv(ws,r,c){
    const a=XLSX.utils.encode_cell({r,c});const cl=ws[a];if(!cl||cl.v==null)return"";
    let str = String(cl.v);
    str = str.replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">");
    return str.replace(/[\u00A0\u200B]/g," ").trim();
}
function esc(s){return String(s??"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")}
async function readWb(f){return XLSX.read(await f.arrayBuffer(),{type:"array",cellDates:true})}

function extractFirstNumber(str) {
  let matches = str.match(/\d+/);
  return matches ? parseInt(matches[0]) : null;
}
function extractBase(str) {
  return str.replace(/\d+/g, "").replace(/[^\p{L}]/gu, "").trim();
}

// [초강력 텍스트 압축] 알파벳(한글 포함)과 숫자만 남기고, 괄호/기호/공백 완벽히 제거
function coreText(s) {
  if (!s) return "";
  return s.replace(/[^\p{L}\p{N}]/gu, "").toLowerCase();
}

// ========== B→C 패턴 학습 ==========
function learnPatterns(bValues, cValues) {
  const tagCount = new Map();
  let pairCount = 0;

  for (let i = 0; i < bValues.length; i++) {
    const b = bValues[i], c = cValues[i];
    if (!b || !c) continue;
    pairCount++;

    const bTags = b.match(/\[[^\]]*\]|\([^)]*\)/g) || [];
    for (const tag of bTags) {
      if (!c.includes(tag.replace(/[\[\]\(\)]/g, ""))) {
        tagCount.set(tag, (tagCount.get(tag) || 0) + 1);
      }
    }
  }

  learnedTags = [...tagCount.entries()]
    .filter(([_, cnt]) => cnt >= 5)
    .sort((a, b) => b[1] - a[1])
    .map(([tag, cnt]) => ({ tag, count: cnt }));

  return { pairCount, tagCount: learnedTags.length };
}

function stripB(b) {
  let s = b;
  for (const { tag } of learnedTags) {
    s = s.split(tag).join("");
  }
  s = s.replace(/\[\d+%?[▼\s]*(할인|대여|세트|대여할인).*?\]/g, " "); 
  s = s.replace(/\[\d+일\s*대여\]/g, " "); 
  s = s.replace(/_?대여기간\s*:\s*\d+일?/g, " "); 
  s = s.replace(/\(외전포함.*?\)/g, " "); 
  s = s.replace(/\s+\d+[\-~]?\d*\s*(화|권|회|편|부|장|절)(\s|$)/g, " ");
  s = s.replace(/\.\s*\d+\s*$/g, "");      
  s = s.replace(/\s+\d+\s*$/g, "");         
  s = s.replace(/\s*\(완결?\)\s*/g, "");     
  s = s.replace(/\s*\[완결?\]\s*/g, "");     
  s = s.replace(/[\u00A0\u200B]/g, " ");            
  return s.trim().replace(/\s+/g, " ");
}

function isPatternMatch(b, c) {
  // [수정] 완벽한 초강력 텍스트 압축 (어떤 유니코드 공백, 기호가 섞여도 걸리지 않음)
  const cleanB = coreText(norm(b));
  const cleanC = coreText(norm(c));
  
  // 조건 1: 남편이 자는데 (세트 혹은 총#권 포함일 때만 시리즈 허용)
  if (cleanB.includes("남편이자는데") && (cleanB.includes("세트") || cleanB.includes("총"))) {
      if (cleanC.includes("남편이자는데시리즈")) return true;
  }
  
  // 조건 2: 침대 위의 연애담 & 신혼담 (세트 포함일 때만 허용)
  if (cleanB.includes("침대위의연애담") && cleanB.includes("신혼담") && cleanB.includes("세트")) {
      if (cleanC.includes("침대위의연애") && cleanC.includes("신혼담")) return true;
  }

  // 조건 3: 밤나비 + 노 모어 프린스 합본 (두 작품명이 모두 존재할 때만 합본으로 인정)
  if (cleanB.includes("밤나비") && cleanB.includes("노모어프린스")) {
      if (cleanC.includes("밀밭단편집")) return true;
  }

  // 강제 패스 사전 확인
  for (const [bKey, cKey] of Object.entries(EXCEPTION_DICT)) {
      if (cleanB.includes(bKey) && cleanC.includes(cKey)) return true;
  }

  // 기본 매칭 (기존 방식 유지)
  let normB = norm(b);
  let normC = norm(c);
  const strippedB = stripB(normB);
  
  const coreBaseB = strippedB.split(/[\(\[:]/)[0].trim();
  const coreBaseC = normC.split(/[\(\[:]/)[0].trim();

  const coreS = coreText(strippedB);
  
  if (!coreS || !cleanC) return true;
  if (coreS === cleanC) return true;
  if (coreS.includes(cleanC) || cleanC.includes(coreS)) return true;
  
  if (coreBaseB.length >= 2 && coreBaseC.length >= 2) {
      if (coreText(coreBaseB) === coreText(coreBaseC)) return true;
      if (coreText(coreBaseC).includes(coreText(coreBaseB))) return true;
  }

  const bTokens = strippedB.split(/[\s\-_\(\)\[\]:,\/&\+]+/).filter(x => x.length >= 2 && !/^\d+$/.test(x));
  if (bTokens.length === 0) return false;

  let matchCount = 0;
  for (const token of bTokens) {
     if (normC.includes(token)) matchCount++;
  }
  
  if (matchCount / bTokens.length >= 0.5) return true;
  return false;
}

function smartMatch(rawTitle, usePlatDirect) {
  if (usePlatDirect) {
    let normRaw = norm(rawTitle);
    if (rdMap.has(normRaw)) return { data: rdMap.get(normRaw), status: "정확 일치" };
  } else {
    if (rdByC.has(rawTitle)) {
      const pick = rdByC.get(rawTitle)[0];
      return { data: { B: pick.B, C: rawTitle, D: pick.D, E: pick.E, F: pick.F, G: pick.G, row: pick.row }, status: "정확 일치" };
    }
  }

  let cleanRaw = norm(rawTitle);
  if (typeof learnedTags !== 'undefined') {
    learnedTags.forEach(t => { cleanRaw = cleanRaw.split(t.tag).join(""); });
  }
  cleanRaw = cleanRaw.trim().replace(/\s+/g, " ");
  let normClean = norm(cleanRaw);
  
  if (usePlatDirect) {
    if (rdMap.has(normClean)) return { data: rdMap.get(normClean), status: "태그 자동제거 매칭" };
  } else {
    if (rdByC.has(cleanRaw)) {
      const pick = rdByC.get(cleanRaw)[0];
      return { data: { B: pick.B, C: cleanRaw, D: pick.D, E: pick.E, F: pick.F, G: pick.G, row: pick.row }, status: "태그 자동제거 매칭" };
    }
  }

  let rawNum = extractFirstNumber(cleanRaw);
  let rawBase = extractBase(cleanRaw);
  let isImplicit = false;
  if (rawNum === null) { rawNum = 1; isImplicit = true; } 

  for (let [dbKey, dbVal] of rdByC.entries()) { 
    let dbBase = extractBase(dbKey);
    let dbNum = extractFirstNumber(dbKey);
    
    if (rawBase && dbBase && (rawBase.includes(dbBase) || dbBase.includes(rawBase))) {
      if (dbNum !== null && rawNum === dbNum) {
        const pick = dbVal[0];
        return { data: { B: pick.B, C: dbKey, D: pick.D, E: pick.E, F: pick.F, G: pick.G, row: pick.row }, status: isImplicit ? "암묵적 1편 매칭" : "시리즈물 파트 매칭" };
      }
    }
  }
  return { data: null, status: "매칭 실패" };
}

// ========== 앵커 기반 자동 탐지 ==========
const ANCHOR_KW = ["서비스월","서비스 월","판매기간","판매월","매출월","서비스기간"];
const ANCHOR_KW2 = ["정산월","정산 월","정산기간"];
const PLAT_TITLE_KW = ["상품명","도서명","콘텐츠명","타이틀","콘텐츠 명","원제","제목","작품명"];
const TYPE_KW = ["구분","유형","형태","상품구분"];

function detectAnchored(ws) {
  const rng = XLSX.utils.decode_range(ws["!ref"] || "A1");
  const maxR = Math.min(rng.e.r, 24);
  const maxC = rng.e.c; 

  let best = null;

  for (let r = 0; r <= maxR; r++) {
    for (let c = 0; c <= maxC; c++) {
      const txt = cv(ws, r, c).replace(/\s+/g, "");
      if (!txt) continue;

      let isSvc = ANCHOR_KW.some(k => txt === k.replace(/\s/g, "") || txt.toLowerCase().includes(k.replace(/\s/g, "")));
      let isSet = ANCHOR_KW2.some(k => txt === k.replace(/\s/g, "") || txt.toLowerCase().includes(k.replace(/\s/g, "")));

      if (isSvc || isSet) {
        let svcCol = isSvc ? c : -1;
        let setCol = isSet ? c : -1;

        if (isSvc && c + 1 <= maxC) {
          const next = cv(ws, r, c + 1).replace(/\s+/g, "");
          if (ANCHOR_KW2.some(k => next === k.replace(/\s/g, "") || next.toLowerCase().includes(k.replace(/\s/g, "")))) {
            setCol = c + 1;
          }
        }
        if (isSet && c - 1 >= 0) {
          const prev = cv(ws, r, c - 1).replace(/\s+/g, "");
          if (ANCHOR_KW.some(k => prev === k.replace(/\s/g, "") || prev.toLowerCase().includes(k.replace(/\s/g, "")))) {
            svcCol = c - 1;
          }
        }

        const anchor = setCol >= 0 ? setCol : (svcCol >= 0 ? svcCol + 1 : c);
        const mapping = {
          svcMonth: svcCol >= 0 ? { col: svcCol, letter: i2c(svcCol), header: cv(ws, r, svcCol) } : null,
          setMonth: setCol >= 0 ? { col: setCol, letter: i2c(setCol), header: cv(ws, r, setCol) } : null,
          realName: { col: anchor + 1, letter: i2c(anchor + 1), header: cv(ws, r, anchor + 1) },
          penName:  { col: anchor + 2, letter: i2c(anchor + 2), header: cv(ws, r, anchor + 2) },
          code:     { col: anchor + 3, letter: i2c(anchor + 3), header: cv(ws, r, anchor + 3) },
          verTitle: { col: anchor + 4, letter: i2c(anchor + 4), header: cv(ws, r, anchor + 4) }
        };

        for (let cc = 0; cc < (svcCol >= 0 ? svcCol : anchor); cc++) {
          const h = cv(ws, r, cc).replace(/\s+/g, "");
          if (TYPE_KW.some(k => h === k)) {
            mapping.type = { col: cc, letter: i2c(cc), header: cv(ws, r, cc) };
            break;
          }
        }

        for (let cc = 0; cc <= maxC; cc++) {
          if (Object.values(mapping).some(m => m && m.col === cc)) continue;
          const h = cv(ws, r, cc).replace(/\s+/g, "");
          if (PLAT_TITLE_KW.some(k => h === k.replace(/\s/g, "") || h.toLowerCase() === k.replace(/\s/g, "").toLowerCase())) {
            mapping.platTitle = { col: cc, letter: i2c(cc), header: cv(ws, r, cc) };
            break;
          }
        }

        const score = Object.values(mapping).filter(Boolean).length;
        if (!best || score > best.score) {
          best = { headerRow: r, mapping, score, anchor: setCol >= 0 ? "정산월" : "서비스월" };
        }
      }
    }
    if (best && best.score >= 5) break; 
  }

  if (!best) best = { headerRow: 0, mapping: {}, score: 0, anchor: "미탐지" };

  const ws2 = ws;
  best.preview = [];
  for (let pr = best.headerRow + 1; pr <= Math.min(best.headerRow + 2, rng.e.r); pr++) {
    const row = {};
    for (const [role, info] of Object.entries(best.mapping)) {
      if (info) row[role] = cv(ws2, pr, info.col);
    }
    best.preview.push(row);
  }
  return best;
}

// ========== 파일 로딩 ==========
function setupDrop(did, iid, fn) {
  const d = $(did);
  ["dragover","dragenter"].forEach(e => d.addEventListener(e, ev => { ev.preventDefault(); d.classList.add("drag") }));
  ["dragleave","drop"].forEach(e => d.addEventListener(e, ev => { ev.preventDefault(); d.classList.remove("drag") }));
  d.addEventListener("drop", e => { e.preventDefault(); fn(e.dataTransfer.files) });
  $(iid).addEventListener("change", e => fn(e.target.files));
}
setupDrop("rdDrop", "rdFile", fs => { if (fs[0]) loadRd(fs[0]) });
setupDrop("psDrop", "psFile", fs => loadPs(fs));

async function loadRd(f) {
  try {
    log(`RD 로드: ${f.name}...`);
    const wb = await readWb(f); RD = { name: f.name, wb };
    $("rdInfo").textContent = `✓ ${f.name} (시트 ${wb.SheetNames.length}개)`;
    const sel = $("rdSh");
    sel.innerHTML = wb.SheetNames.map(s => `<option value="${s}">${s}</option>`).join("");
    const g = wb.SheetNames.find(s => s.includes("정산용")) || wb.SheetNames.find(s => s.includes("RD취합"));
    if (g) sel.value = g;
    log("RD 로드 완료", "o");
  } catch (e) { log("RD 실패: " + e.message, "e"); alert(e.message) }
}

async function loadPs(files) {
  for (const f of files) {
    try {
      if (f.name.includes("원작료")) {
          log(`[제외] ${f.name} (원작료 파일은 검증 대상 아님)`, "o");
          continue;
      }

      log(`정산서 분석: ${f.name}...`);
      const wb = await readWb(f);
      const id = "p" + Date.now() + Math.random().toString(36).slice(2, 5);
      const detections = {};
      let bestSheet = null;

      const rawSheet = wb.SheetNames.find(s => s.trim().toLowerCase() === "raw");
      
      if (rawSheet) {
          const det = detectAnchored(wb.Sheets[rawSheet]);
          detections[rawSheet] = det;
          bestSheet = rawSheet;
      } else {
          let bestScore = -1;
          for (const sn of wb.SheetNames) {
              const det = detectAnchored(wb.Sheets[sn]);
              detections[sn] = det;
              if (det.score > bestScore) { bestScore = det.score; bestSheet = sn; }
          }
      }
      
      const preferSheet = bestSheet || wb.SheetNames[0];
      PS.push({ id, name: f.name, wb, sheet: preferSheet, detections });
      const det = detections[preferSheet];
      log(`${f.name} → "${preferSheet}" 시트, 앵커="${det.anchor}", ${det.score}개 열 탐지`, "o");
    } catch (e) { log(`${f.name} 실패: ${e.message}`, "e") }
  }
  renderPsCards();
}

const ROLE_LABEL = {
  platTitle: "플랫폼작품명(키)", verTitle: "작품명(당사)", realName: "본명",
  penName: "필명", code: "작품코드", type: "구분", svcMonth: "서비스월", setMonth: "정산월"
};
const DISPLAY_ORDER = ["platTitle","svcMonth","setMonth","realName","penName","code","verTitle","type"];

function renderPsCards() {
  const container = $("psCards"); container.innerHTML = "";
  PS.forEach((f, idx) => {
    const det = f.detections[f.sheet] || { headerRow: 0, mapping: {}, score: 0, anchor: "미탐지", preview: [] };
    const card = document.createElement("div"); card.className = "det-card"; card.id = "card_" + f.id;
    const sheetOpts = f.wb.SheetNames.map(s => `<option value="${s}" ${s === f.sheet ? "selected" : ""}>${s}</option>`).join("");

    const rng = XLSX.utils.decode_range(f.wb.Sheets[f.sheet]["!ref"] || "A1");
    const allCols = [];
    for (let c = 0; c <= Math.min(rng.e.c, 199); c++) {
      const hdr = cv(f.wb.Sheets[f.sheet], det.headerRow, c);
      if (hdr) allCols.push({ col: c, letter: i2c(c), header: hdr });
    }

    let mapHtml = "";
    for (const role of DISPLAY_ORDER) {
      const info = det.mapping[role];
      const cls = info ? "found" : "miss";
      const opts = `<option value="">없음</option>` +
        allCols.map(ac => `<option value="${ac.letter}" ${info && info.letter === ac.letter ? "selected" : ""}>${ac.letter}: ${ac.header}</option>`).join("");
      mapHtml += `<div class="map-item"><span class="map-role ${cls}">${ROLE_LABEL[role]}</span><select data-id="${f.id}" data-role="${role}" onchange="updateMap(this)">${opts}</select></div>`;
    }

    const mapped = Object.entries(det.mapping).filter(([_, v]) => v);
    let prevHtml = "";
    if (mapped.length > 0 && det.preview.length > 0) {
      prevHtml = `<div class="preview"><table><tr>${mapped.map(([r]) => `<th>${ROLE_LABEL[r] || r}</th>`).join("")}</tr>`;
      for (const row of det.preview) prevHtml += `<tr>${mapped.map(([r]) => `<td>${esc(row[r] || "")}</td>`).join("")}</tr>`;
      prevHtml += `</table></div>`;
    }

    card.innerHTML = `
      <div class="det-title">
        <span class="fn">${idx + 1}. ${f.name}</span>
        <span class="badge ${det.score >= 4 ? "bok" : det.score >= 2 ? "bw" : "be"}">${det.score >= 4 ? "✓ 자동 탐지 완료" : det.score >= 2 ? "⚠ 일부 탐지" : "✗ 탐지 실패"}</span>
        <span class="anchor-info">앵커: ${det.anchor} (${det.headerRow + 1}행)</span>
        <button class="bdel" onclick="rmPs('${f.id}')">삭제</button>
      </div>
      <div class="sheet-sel">시트: <select data-id="${f.id}" onchange="chSheet(this)">${sheetOpts}</select></div>
      <div class="map-grid">${mapHtml}</div>
      ${prevHtml}`;
    container.appendChild(card);
  });
}

function chSheet(sel) {
  const f = PS.find(x => x.id === sel.dataset.id); if (!f) return;
  f.sheet = sel.value;
  if (!f.detections[f.sheet]) f.detections[f.sheet] = detectAnchored(f.wb.Sheets[f.sheet]);
  renderPsCards();
}
function updateMap(sel) {
  const f = PS.find(x => x.id === sel.dataset.id); if (!f) return;
  const det = f.detections[f.sheet], role = sel.dataset.role, letter = sel.value;
  if (letter) {
    const col = c2i(letter); det.mapping[role] = { col, letter, header: cv(f.wb.Sheets[f.sheet], det.headerRow, col) };
  } else delete det.mapping[role];
  const rng = XLSX.utils.decode_range(f.wb.Sheets[f.sheet]["!ref"] || "A1");
  det.preview = [];
  for (let pr = det.headerRow + 1; pr <= Math.min(det.headerRow + 2, rng.e.r); pr++) {
    const row = {}; for (const [r2, info] of Object.entries(det.mapping)) { if (info) row[r2] = cv(f.wb.Sheets[f.sheet], pr, info.col); }
    det.preview.push(row);
  }
  renderPsCards();
}
function rmPs(id) { PS = PS.filter(x => x.id !== id); renderPsCards() }
function resetAll() {
  if (!confirm("초기화?")) return;
  RD = null; PS = []; rdMap = null; rdByC = null; rIss = []; pIss = []; pSta = []; rdTotal = 0;
  $("rdInfo").textContent = ""; $("rdSh").innerHTML = "<option>(로드 후 선택)</option>";
  $("psCards").innerHTML = ""; $("resCard").style.display = "none"; clearLog();
}

// ========== Req 1: RD 검증 ==========
function buildRd() {
  rIss = []; rdMap = new Map(); rdByC = new Map(); rdTotal = 0;
  riskyBKeys.clear();
  
  if (!RD) throw new Error("RD 파일 먼저 업로드");
  const sn = $("rdSh").value; if (!sn) throw new Error("RD 시트 선택 필요");
  const ws = RD.wb.Sheets[sn]; if (!ws) throw new Error(`시트 '${sn}' 없음`);
  const hdr = Number($("rdHdr").value) || 5;
  const iB = c2i($("rB").value), iC = c2i($("rC").value), iD = c2i($("rD").value),
        iE = c2i($("rE").value), iF = c2i($("rF").value), iG = c2i($("rG").value);
  if ([iB, iC, iD, iE, iF, iG].some(x => x < 0)) throw new Error("RD 열 문자 오류");
  const rng = XLSX.utils.decode_range(ws["!ref"] || "A1");

  const bArr = [], cArr = [];
  const allRows = [];
  for (let r = hdr; r <= rng.e.r; r++) {
    const b = cv(ws, r, iB), c = cv(ws, r, iC), d = cv(ws, r, iD), e = cv(ws, r, iE), f = cv(ws, r, iF), g = cv(ws, r, iG);
    if (!b && !c && !d && !e) continue;
    allRows.push({ b, c, d, e, f, g, row: r + 1 });
    bArr.push(b); cArr.push(c);
  }
  rdTotal = allRows.length;

  const learnResult = learnPatterns(bArr, cArr);
  log(`패턴 학습: ${learnResult.pairCount}쌍 분석 → ${learnResult.tagCount}개 태그 패턴 추출`, "o");

  const variationMap = new Map();
  for (const { b, c } of allRows) {
      if (!b || !c) continue;
      const cb = coreText(stripB(norm(b)));
      const cc = coreText(norm(c));
      const key = cb + "||" + cc;
      variationMap.set(key, (variationMap.get(key) || 0) + 1);
  }

  for (const { b, c, d, e, f, g, row } of allRows) {
    if (b && !c) rIss.push({ row, type: "C열 작품명 누락", b, c, detail: "B열은 있으나 C열이 비어있음" });
    if (!b && c) rIss.push({ row, type: "B열 플랫폼작품명 누락", b, c, detail: "C열은 있으나 B열이 비어있음" });
    if (b && c && !d && !e) rIss.push({ row, type: "작품코드 모두 누락", b, c, detail: "연재·단행본 코드 둘 다 비어있음" });

    if (b) {
      const key = norm(b);
      if (rdMap.has(key)) {
        const prev = rdMap.get(key);
        if (prev.C !== c || prev.D !== d || prev.E !== e || prev.F !== f || prev.G !== g)
          rIss.push({ row, type: "중복 B열 (매핑 불일치)", b, c: `${c} vs ${prev.C}`, detail: `행 ${prev.row}과 다른 매핑` });
      } else rdMap.set(key, { B: b, C: c, D: d, E: e, F: f, G: g, row, origKey: b });
    }
    if (c) { if (!rdByC.has(c)) rdByC.set(c, []); rdByC.get(c).push({ B: b, D: d, E: e, F: f, G: g, row }); }
  }

  for (const [cVal, rows] of rdByC.entries()) {
    const normCVal = norm(cVal);
    // [수정] 그룹 관대함을 위해 C열 텍스트를 제대로 쪼갬
    const cTokens = normCVal.split(/[\s\-_\(\)\[\]\+]+/).filter(x => x.length >= 2 && !/^\d+$/.test(x));

    for (const r of rows) {
      if (!r.B) continue;
      const key = coreText(stripB(norm(r.B))) + "||" + coreText(normCVal);
      
      let isGroupRuleMatch = false;
      let cTokensMatched = 0;
      const bText = stripB(norm(r.B));

      for (const cToken of cTokens) {
          if (bText.includes(cToken)) cTokensMatched++;
      }
      
      if (cTokensMatched > 0 && rows.length >= 2) {
          isGroupRuleMatch = true;
      }

      if (!isPatternMatch(r.B, cVal) && !isGroupRuleMatch && variationMap.get(key) < 2) {
         if (rows.length < 2) {
             rIss.push({ row: r.row, type: "B→C 패턴 불일치", b: r.B, c: cVal, detail: `단어 일치율 미달 및 사전에 없는 단발성 매핑` });
             riskyBKeys.add(norm(r.B));
         } else {
             rIss.push({ row: r.row, type: "C그룹 내 이상 B값", b: r.B, c: cVal, detail: `그룹 공통 규칙(단편집 등)을 벗어난 이질적 B` });
             riskyBKeys.add(norm(r.B));
         }
      }
    }
  }

  log(`RD: ${rdTotal}행 / B ${rdMap.size} / C ${rdByC.size} / 이슈 ${rIss.length}`, "o");
  return { total: rdTotal, uB: rdMap.size, uC: rdByC.size };
}

// ========== Req 2: 정산서 검증 ==========
function verifyPs(fo) {
  const det = fo.detections[fo.sheet];
  if (!det || det.score === 0) { pIss.push(pErr(fo, "-", "탐지 실패", "헤더 자동 탐지 실패. 시트를 변경하거나 열을 수동 지정하세요.")); return 0; }
  const ws = fo.wb.Sheets[fo.sheet]; if (!ws) { pIss.push(pErr(fo, "-", "시트 없음", fo.sheet)); return 0; }
  const m = det.mapping;

  const iPl = m.platTitle ? m.platTitle.col : (m.verTitle ? m.verTitle.col : -1);
  const usePlatDirect = !!m.platTitle; 
  if (iPl < 0) { pIss.push(pErr(fo, "-", "작품명 열 없음", "플랫폼작품명/작품명 열을 찾지 못함")); return 0; }
  const iTi = m.verTitle ? m.verTitle.col : -1;
  const iRe = m.realName ? m.realName.col : -1;
  const iPe = m.penName ? m.penName.col : -1;
  const iCo = m.code ? m.code.col : -1;
  const iTy = m.type ? m.type.col : -1;
  const startRow = det.headerRow + 1;
  const rng = XLSX.utils.decode_range(ws["!ref"] || "A1");
  let cnt = 0;

  for (let r = startRow; r <= rng.e.r; r++) {
    const keyVal = cv(ws, r, iPl); if (!keyVal) continue;
    cnt++; const rn = r + 1;
    const title = iTi >= 0 && iTi !== iPl ? cv(ws, r, iTi) : "";
    const real = iRe >= 0 ? cv(ws, r, iRe) : "";
    const pen = iPe >= 0 ? cv(ws, r, iPe) : "";
    const code = iCo >= 0 ? cv(ws, r, iCo) : "";
    const typ = iTy >= 0 ? cv(ws, r, iTy) : "";
    const base = { file: fo.name, sheet: fo.sheet, row: rn, plat: keyVal, psTi: title, psRe: real, psPe: pen, psCo: code, rdTi: "", rdRe: "", rdPe: "", rdCoS: "", rdCoD: "" };

    let matchResult = smartMatch(keyVal, usePlatDirect);
    let rd = matchResult.data;

    const svcMo = m.svcMonth ? cv(ws, r, m.svcMonth.col) : "";
    const setMo = m.setMonth ? cv(ws, r, m.setMonth.col) : "";
    let platName = fo.name.split("_")[0].replace(".xlsx", "").replace(".csv", "");
    let vStatus = "에러";
    let vDetail = matchResult.status || "RD에서 찾을 수 없음";
    let outC = keyVal, outReal = real, outPen = pen, outCode = code;

    if (!rd) {
      pIss.push({ ...base, type: usePlatDirect ? "RD에 없는 플랫폼작품명" : "RD에 없는 작품명",
        detail: `"${keyVal}" → RD에서 찾을 수 없음` }); 
    } else {
      base.rdTi = rd.C; base.rdRe = rd.F; base.rdPe = rd.G; base.rdCoS = rd.D; base.rdCoD = rd.E;
      
      outC = rd.C; outReal = rd.F; outPen = rd.G;
      if (typ.includes("연재")) outCode = rd.D;
      else if (typ.includes("단행")) outCode = rd.E;
      else outCode = rd.D || rd.E;
      
      vStatus = "정상";
      let hasErr = false;

      if (riskyBKeys.has(norm(keyVal))) {
          hasErr = true;
          pIss.push({ ...base, type: "RD 마스터 매핑 오류 의심", detail: `[경고] RD 관리 파일에서 이질적이거나 패턴이 불일치하는 작품으로 판정된 내역입니다. (RD C열: ${rd.C})` });
          vDetail = "RD 매핑 오류 의심 (Req1 확인 요망)";
      }

      if (iTi >= 0 && iTi !== iPl && title) {
        const normTitle = norm(title);
        const normExpected = norm(rd.C);
        if (normTitle !== normExpected) { hasErr=true; pIss.push({ ...base, type: "작품명 불일치", detail: `정산서=[${title}] vs RD=[${rd.C}]` }); }
      }
      if (iRe >= 0 && (real || rd.F) && norm(real) !== norm(rd.F)) {
        hasErr=true; pIss.push({ ...base, type: "본명 불일치", detail: `정산서=[${real}] vs RD=[${rd.F}]` });
      }
      if (iPe >= 0 && (pen || rd.G) && norm(pen) !== norm(rd.G)) {
        hasErr=true; pIss.push({ ...base, type: "필명 불일치", detail: `정산서=[${pen}] vs RD=[${rd.G}]` });
      }
      if (iCo >= 0 && code) {
        let expect = "";
        if (typ.includes("연재")) expect = rd.D;
        else if (typ.includes("단행")) expect = rd.E;
        if (expect) { 
            if (norm(code) !== norm(expect)) { hasErr=true; pIss.push({ ...base, type: "작품코드 불일치", detail: `정산서=[${code}] vs RD=[${expect}] (${typ})` }); }
        }
        else { 
            if (norm(code) !== norm(rd.D) && norm(code) !== norm(rd.E)) { hasErr=true; pIss.push({ ...base, type: "작품코드 불일치", detail: `정산서=[${code}] vs RD 연재=[${rd.D}] 단행=[${rd.E}]` }); }
        }
      }

      if (hasErr) {
          vStatus = "에러";
          if (!vDetail.includes("RD 매핑 오류 의심")) vDetail = "데이터 불일치 (리포트 참고)";
      }
    }
    
    finalOutput.push([platName, typ, "", "", svcMo, setMo, outReal, outPen, outCode, outC, vStatus, vDetail]);
  }
  return cnt;
}
function pErr(f, row, type, detail) {
  return { file: f.name, sheet: f.sheet || "", row, type, plat: "", psTi: "", psRe: "", psPe: "", psCo: "", rdTi: "", rdRe: "", rdPe: "", rdCoS: "", rdCoD: "", detail };
}

// ========== 실행 ==========
async function runRd() {
  try { $("resCard").style.display = "block"; log("── Req 1 ──"); const i = buildRd(); pIss = []; pSta = []; drawRes({ ...i, psCnt: 0 }); }
  catch (e) { log("오류: " + e.message, "e"); alert(e.message) } }
async function runAll() {
  try {
    if (!RD) return alert("RD 파일 먼저"); if (!PS.length) return alert("정산서 추가");
    $("resCard").style.display = "block"; log("── 전체 검증 ──");
    const t0 = performance.now(); const info = buildRd();
    pIss = []; pSta = []; let tot = 0;
    
    finalOutput = [["플랫폼", "구분", "코드", "부서명", "서비스월", "정산월", "작가명(본명)", "작가명(필명)", "작품코드", "작품명", "검증 상태", "매칭 방식/상세"]];

    for (const f of PS) { log(`검증: ${f.name} (${f.sheet})...`); const n = verifyPs(f); pSta.push({ file: f.name, rows: n }); tot += n; }
    log(`완료 (${((performance.now() - t0) / 1000).toFixed(1)}초): ${tot}행 / 이슈 ${pIss.length}`, "o");
    drawRes({ ...info, psCnt: tot });
  } catch (e) { log("오류: " + e.message, "e"); alert(e.message) } }

// ========== 결과 ==========
function stab(w) { document.querySelectorAll(".tab").forEach(t => t.classList.toggle("on", t.dataset.t === w)); document.querySelectorAll(".tc").forEach(t => t.classList.toggle("on", t.id === "t-" + w)) }
function drawRes(s) {
  $("sum").innerHTML = `
    <div class="sum-b"><div class="n">${s.total||0}</div><div class="l">RD 행수</div></div>
    <div class="sum-b"><div class="n">${s.uB||0}</div><div class="l">고유 B</div></div>
    <div class="sum-b"><div class="n">${s.uC||0}</div><div class="l">고유 C</div></div>
    <div class="sum-b" style="border-color:#fbbf24"><div class="n" style="color:#b45309">${rIss.length}</div><div class="l">Req1 이슈</div></div>
    <div class="sum-b"><div class="n">${s.psCnt||0}</div><div class="l">정산서 행</div></div>
    <div class="sum-b" style="border-color:#ef4444"><div class="n" style="color:#b91c1c">${pIss.length}</div><div class="l">Req2 이슈</div></div>`;

  if (learnedTags.length > 0) {
    const top10 = learnedTags.slice(0, 10).map(t => `<span class="badge bi">${esc(t.tag)} (${t.count}회)</span>`).join(" ");
    $("rdPatternInfo").innerHTML = `<div style="font-size:11px;color:#475569;margin-bottom:6px"><b>학습된 B→C 삭제 태그 Top ${Math.min(10, learnedTags.length)}:</b> ${top10}${learnedTags.length > 10 ? ` 외 ${learnedTags.length - 10}개` : ""}</div>`;
  } else $("rdPatternInfo").innerHTML = "";

  const rt = [...new Set(rIss.map(x => x.type))].sort();
  $("rflt").innerHTML = `<option value="">전체 (${rIss.length})</option>` + rt.map(t => `<option value="${t}">${t} (${rIss.filter(x => x.type === t).length})</option>`).join("");
  const pt = [...new Set(pIss.map(x => x.type))].sort();
  $("pflt").innerHTML = `<option value="">전체 (${pIss.length})</option>` + pt.map(t => `<option value="${t}">${t} (${pIss.filter(x => x.type === t).length})</option>`).join("");
  const pf = [...new Set(pIss.map(x => x.file))].sort();
  $("pffl").innerHTML = `<option value="">전체</option>` + pf.map(f => `<option value="${f}">${f}</option>`).join("");
  drawRd(); drawPs();
}
function drawRd() {
  const fv = $("rflt").value; const rows = fv ? rIss.filter(x => x.type === fv) : rIss;
  $("rcnt").textContent = `${rows.length}건`;
  const t = $("rTbl");
  t.querySelector("thead").innerHTML = `<tr><th>행</th><th>이슈</th><th>B(플랫폼작품명)</th><th>C(당사작품명)</th><th>상세</th></tr>`;
  t.querySelector("tbody").innerHTML = rows.length === 0 ? `<tr><td colspan="5" style="text-align:center;color:#059669;padding:14px">✓ 이슈 없음</td></tr>`
    : rows.map(x => `<tr><td>${x.row}</td><td><span class="badge ${bc(x.type)}">${esc(x.type)}</span></td><td>${esc(x.b)}</td><td>${esc(x.c)}</td><td>${esc(x.detail)}</td></tr>`).join("");
}
function drawPs() {
  let rows = pIss; const ft = $("pflt").value, ff = $("pffl").value;
  if (ft) rows = rows.filter(x => x.type === ft); if (ff) rows = rows.filter(x => x.file === ff);
  $("pcnt").textContent = `${rows.length}건`;
  const t = $("pTbl");
  t.querySelector("thead").innerHTML = `<tr><th>파일</th><th>시트</th><th>행</th><th>이슈</th><th>조회키</th><th>정산서 작품명</th><th>RD 작품명</th><th>정산서 본명</th><th>RD 본명</th><th>정산서 필명</th><th>RD 필명</th><th>정산서 코드</th><th>RD 연재</th><th>RD 단행</th><th>상세</th></tr>`;
  t.querySelector("tbody").innerHTML = rows.length === 0 ? `<tr><td colspan="15" style="text-align:center;color:#059669;padding:14px">✓ 이슈 없음</td></tr>`
    : rows.map(x => `<tr><td class="fn">${esc(x.file)}</td><td>${esc(x.sheet)}</td><td>${x.row}</td><td><span class="badge ${bc(x.type)}">${esc(x.type)}</span></td><td>${esc(x.plat)}</td><td>${esc(x.psTi)}</td><td>${esc(x.rdTi)}</td><td>${esc(x.psRe)}</td><td>${esc(x.rdRe)}</td><td>${esc(x.psPe)}</td><td>${esc(x.rdPe)}</td><td>${esc(x.psCo)}</td><td>${esc(x.rdCoS)}</td><td>${esc(x.rdCoD)}</td><td>${esc(x.detail)}</td></tr>`).join("");
}
function bc(t) { return t.includes("불일치") || t.includes("없는") || t.includes("의심") ? "be" : t.includes("이상") || t.includes("누락") || t.includes("공백") || t.includes("낮음") || t.includes("패턴") ? "bw" : "bi" }

// ========== 엑셀 내보내기 ==========
function exportXlsx() {
  const wb = XLSX.utils.book_new();
  
  const s0 = XLSX.utils.aoa_to_sheet([["정산서 검증 결과 요약"], ["검증일시", new Date().toLocaleString("ko-KR")], ["RD 파일", RD ? RD.name : ""], ["RD 행수", rdTotal], ["학습 태그", learnedTags.length + "개"], ["Req1 이슈", rIss.length], ["Req2 이슈", pIss.length], [], ["■ Req1 유형별"], ...tally(rIss.map(x => x.type)), [], ["■ Req2 유형별"], ...tally(pIss.map(x => x.type)), [], ["■ 파일별 처리 행수"], ["파일", "행수"], ...pSta.map(s => [s.file, s.rows])]);
  s0["!cols"] = [{ wch: 38 }, { wch: 22 }]; XLSX.utils.book_append_sheet(wb, s0, "요약");
  
  const h1 = ["RD행", "이슈", "B(플랫폼작품명)", "C(당사작품명)", "상세"];
  const s1 = XLSX.utils.aoa_to_sheet([h1, ...rIss.map(x => [x.row, x.type, x.b, x.c, x.detail])]);
  s1["!cols"] = [{ wch: 7 }, { wch: 24 }, { wch: 38 }, { wch: 38 }, { wch: 60 }];
  XLSX.utils.book_append_sheet(wb, s1, "Req1_RD검증");
  
  const h2 = ["파일", "시트", "행", "이슈", "플랫폼작품명", "정산서작품명", "RD작품명", "정산서본명", "RD본명", "정산서필명", "RD필명", "정산서코드", "RD연재", "RD단행", "상세"];
  const s2 = XLSX.utils.aoa_to_sheet([h2, ...pIss.map(x => [x.file, x.sheet, x.row, x.type, x.plat, x.psTi, x.rdTi, x.psRe, x.rdRe, x.psPe, x.rdPe, x.psCo, x.rdCoS, x.rdCoD, x.detail])]);
  s2["!cols"] = [{ wch: 24 }, { wch: 10 }, { wch: 6 }, { wch: 22 }, { wch: 28 }, { wch: 24 }, { wch: 24 }, { wch: 12 }, { wch: 12 }, { wch: 12 }, { wch: 12 }, { wch: 12 }, { wch: 12 }, { wch: 12 }, { wch: 50 }];
  XLSX.utils.book_append_sheet(wb, s2, "Req2_정산서검증");

  if (finalOutput && finalOutput.length > 1) {
      const s3 = XLSX.utils.aoa_to_sheet(finalOutput);
      s3["!cols"] = [{ wch: 15 }, { wch: 10 }, { wch: 10 }, { wch: 10 }, { wch: 12 }, { wch: 12 }, { wch: 15 }, { wch: 15 }, { wch: 15 }, { wch: 35 }, { wch: 10 }, { wch: 30 }];
      XLSX.utils.book_append_sheet(wb, s3, "당사검증내역(10열)");
  }

  const d = new Date();
  const st = d.getFullYear() + String(d.getMonth() + 1).padStart(2, "0") + String(d.getDate()).padStart(2, "0") + "_" + String(d.getHours()).padStart(2, "0") + String(d.getMinutes()).padStart(2, "0");
  XLSX.writeFile(wb, `정산서_검증결과_${st}.xlsx`);
}
function tally(a) { const m = new Map(); a.forEach(k => m.set(k, (m.get(k) || 0) + 1)); return [...m.entries()].sort((a, b) => b[1] - a[1]) }
</script>
