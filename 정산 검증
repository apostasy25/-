<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<title>정산서 검증기 v3 (최종 완전체)</title>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
*{box-sizing:border-box}
body{font-family:"맑은 고딕","Malgun Gothic",-apple-system,sans-serif;margin:0;padding:20px 24px;background:#f5f6f8;color:#1e293b;font-size:13px}
h1{margin:0 0 4px;font-size:21px;color:#0f172a}
.sub{color:#64748b;margin-bottom:18px;font-size:12px}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:16px 20px;margin-bottom:14px;box-shadow:0 1px 2px rgba(0,0,0,.04)}
.card h2{margin:0 0 12px;font-size:14px;color:#fff;padding:7px 12px;border-radius:6px;display:inline-block}
.hg{background:#059669}.hb{background:#2563eb}.ho{background:#ea580c}.hp{background:#7c3aed}
.row{display:flex;align-items:center;gap:8px;margin-bottom:7px;flex-wrap:wrap}
label{min-width:120px;font-size:12px;color:#475569;font-weight:600}
input[type=text],input[type=number],select{padding:5px 8px;border:1px solid #cbd5e1;border-radius:5px;font-size:12px}
button{padding:7px 14px;background:#2563eb;color:#fff;border:0;border-radius:5px;cursor:pointer;font-size:12px;font-weight:600;transition:.15s}
